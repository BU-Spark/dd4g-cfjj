# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=sro-complaints-data-your-project-id
LOCATION=us-east5

# Google AI API Key (for Gemini)
# Get your API key from: https://aistudio.google.com/apikey
# If you hit quota limits: wait for daily reset, enable billing, or get a new key
GOOGLE_API_KEY=your-google-api-key-here

# Gemini Model
# Options: gemini-2.5-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# Clerk Authentication
# Get from: Clerk Dashboard → Configure → API Keys
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here

# MongoDB
# Get from: MongoDB Atlas → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Cache Configuration (optional, uses defaults if not set)
# QUERY_CACHE_TTL=300    # Query cache TTL in seconds (default: 5 minutes)
# CORPUS_CACHE_TTL=3600  # Corpus cache TTL in seconds (default: 1 hour)

# Rate Limiting (optional, uses defaults if not set)
# MAX_REQUESTS_PER_MINUTE=10  # Max queries per minute (default: 10)
